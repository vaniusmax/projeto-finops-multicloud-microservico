APP_NAME="FinOps Micro API"
APP_ENV=dev
DEBUG=false
API_PREFIX=/api/v1
AUTO_INGEST_ON_REQUEST=true

# Conexao local para o Postgres rodando em container Docker com porta 5432 publicada
DATABASE_URL=postgresql+psycopg2://finops:finops123@127.0.0.1:5432/finops
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# AWS CLI ingest
AWS_PROFILE=
AWS_TENANTS=
AWS_CLI_PATH=aws
AWS_ACCOUNT_NAMES_JSON={"555136764052":"Algar Brain VM","937406753822":"Algar Security","595949041525":"Algar Telecom","209663503877":"AlgarAppDEV","655629219208":"AlgarAppHOM","669477896728":"AlgarAppPRD","518919108570":"AlgarDataLakeDev","149748488652":"Estacao de Experiencias Digitais","838968885358":"Gestao de Marketplace DEV","752725527618":"poc-aiops"}

# Azure CLI ingest
AZURE_MANAGEMENT_GROUP_ID=mg-algar-finops
AZURE_TENANTS=
AZURE_API_VERSION=2023-11-01
AZURE_CLI_PATH=az

# OCI CLI ingest
OCI_TENANT_ID=ocid1.tenancy.oc1..aaaaaaaa2mqkus3demgbgrfae7nnkf7pixl5ngrcosast7u264mphve4vuaq
OCI_PROFILE=DEFAULT
OCI_TENANTS=
OCI_REGION=sa-saopaulo-1
OCI_CLI_PATH=oci

# Config opcional por tenant:
# {"oci":{"OCI-TENANT-OCVS":{"profile":"OCI-TENANT-OCVS","tenant_id":"ocid1.tenancy..."}}}
TENANT_CONFIGS_JSON={}

# Metas para cards da Visao Geral (summary_v2)
TARGET_MONTHLY_BRL=0
TARGET_WEEKLY_BRL=0
TARGET_MONTHLY_USD=0
TARGET_WEEKLY_USD=0

# Overrides de meta mensal por cloud (apenas BRL), formato JSON:
# {"aws":{"2026-01":120000,"2026-02":138530},"azure":{"2026-02":95000},"all":{"2026-03":100000}}
MONTHLY_TARGETS_JSON=

# Sincronizacao da cotacao USD/BRL para dim_currency_rate
CURRENCY_RATE_SYNC_ON_REQUEST=true
CURRENCY_RATE_PROVIDER_URL=https://economia.awesomeapi.com.br/json/daily/USD-BRL/1
CURRENCY_RATE_TIMEOUT_SECONDS=10
CURRENCY_RATE_AGNO_ENABLED=false
CURRENCY_RATE_YFINANCE_ENABLED=true
CURRENCY_RATE_YFINANCE_SYMBOL=BRL=X
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=

# Fallback da cotacao USD (BRL por USD) quando dim_currency_rate nao tiver dados
USD_RATE_FALLBACK=
